{
  "_comment": "Recorded-shape public WebSocket trade frames, one (or two, for channel-id protocols) per venue. Field names and value formats match the live feeds; values are illustrative. Used by tests/test_sources_parse.py to exercise each adapter's normalization path with no network.",
  "binance": {
    "canonical": "BTC-USDT",
    "kind": "decoded_dict",
    "frames": [
      {"stream": "btcusdt@trade", "data": {"e": "trade", "E": 1778600000123, "s": "BTCUSDT", "t": 987654321, "p": "61234.50000000", "q": "0.01230000", "b": 100, "a": 200, "T": 1778600000111, "m": false, "M": true}}
    ],
    "expect": {"symbol": "BTC-USDT", "venue": "binance", "price": 61234.5, "size": 0.0123, "side": 1, "ts_ns": 1778600000111000000, "trade_id": "987654321"}
  },
  "coinbase": {
    "canonical": "BTC-USD",
    "kind": "raw_str",
    "frames": [
